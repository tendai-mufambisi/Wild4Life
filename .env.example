# ─── Django Core ────────────────────────────────────────────────────────────────
# Generate a real key with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here-replace-with-real-value

# Set to False in production
DEBUG=True

# Comma-separated. Example: localhost,127.0.0.1,yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated full origins (scheme+domain) Django will accept CSRF tokens from
# Must include every domain visitors use, with https:// prefix
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Database URL. Default uses SQLite for local dev.
# For Postgres: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=sqlite:///db.sqlite3

# ─── Paynow Integration ─────────────────────────────────────────────────────────
# Obtain from: https://www.paynow.co.zw/Payment/GetIntegrationDetails
# TEST credentials: use the Integration ID/Key from your Paynow test merchant account
PAYNOW_INTEGRATION_ID=your-integration-id
PAYNOW_INTEGRATION_KEY=your-integration-key

# Where Paynow redirects the donor's browser after payment attempt
# Must be publicly reachable. For local dev use ngrok: https://xxxx.ngrok.io/donation/return/
PAYNOW_RETURN_URL=http://localhost:8000/donation/return/

# Where Paynow POSTs server-to-server payment status updates (IPN)
# Must be publicly reachable. Cannot be localhost in production.
PAYNOW_RESULT_URL=http://localhost:8000/paynow/result/

# ─── Site ────────────────────────────────────────────────────────────────────────
SITE_BASE_URL=http://localhost:8000

# Default currency for donations. Choices: USD, ZWG
DEFAULT_CURRENCY=USD

# ─── Email (production SMTP) ─────────────────────────────────────────────────────
# In DEBUG=True mode the console email backend is used automatically.
# Fill these in for production (DEBUG=False):
EMAIL_HOST=smtp.yourprovider.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@yourprovider.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=Wild4Life Donations <donations@wild4life.org.zw>

# ─── Admin Bootstrap ─────────────────────────────────────────────────────────────
# Used only by: python manage.py createadmin
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@wild4life.org.zw
DJANGO_SUPERUSER_PASSWORD=change-me-immediately
